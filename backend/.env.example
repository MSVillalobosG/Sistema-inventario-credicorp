# Copie este archivo como .env y ajuste los valores.

# --- Opción A: Postgres (Supabase u otro) ---
# Project Settings → Database → Connection string (URI).
# Si ve "tenant/user postgres.xxx not found", el proyecto fue pausado, borrado o la URL está desactualizada:
# genere una nueva cadena en el panel de Supabase.
# DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
# Para pooler modo transacción (6543) suele ir bien:
# DATABASE_USE_NULL_POOL=true

# --- Opción B: SQLite en su PC (sin Supabase) ---
USE_LOCAL_SQLITE=true

# JWT para login del dashboard (cambie en producción). Use el mismo valor en cada arranque o todos los tokens caducan.
# JWT_SECRET=cambie_esto_por_un_secreto_largo
# (tambien se acepta JWT_SECRET_KEY por compatibilidad)
